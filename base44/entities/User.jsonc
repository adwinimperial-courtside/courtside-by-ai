{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "phone": {
      "type": "string"
    },
    "phone_verified": {
      "type": "boolean",
      "default": false
    },
    "phone_verify_code": {
      "type": "string"
    },
    "phone_verify_expires": {
      "type": "string"
    }
  }
}