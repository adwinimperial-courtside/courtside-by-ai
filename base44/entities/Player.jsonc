{
  "name": "Player",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Player full name"
    },
    "team_id": {
      "type": "string",
      "description": "Reference to the team"
    },
    "jersey_number": {
      "type": "number",
      "description": "Player jersey number"
    },
    "position": {
      "type": "string",
      "enum": [
        "PG",
        "SG",
        "SF",
        "PF",
        "C"
      ],
      "description": "Player position"
    },
    "photo_url": {
      "type": "string",
      "description": "URL of the player's profile photo uploaded by a league admin. Displayed across the app wherever the player appears. When empty, the app falls back to showing the jersey number circle."
    }
  },
  "required": [
    "name",
    "team_id",
    "jersey_number"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "data.user_type": "app_admin"
          }
        },
        {
          "user_condition": {
            "data.user_type": "league_admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "data.user_type": "app_admin"
          }
        },
        {
          "user_condition": {
            "data.user_type": "league_admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "data.user_type": "app_admin"
          }
        },
        {
          "user_condition": {
            "data.user_type": "league_admin"
          }
        }
      ]
    },
    "write": {
      "$or": [
        {
          "user_condition": {
            "data.user_type": "app_admin"
          }
        },
        {
          "user_condition": {
            "data.user_type": "league_admin"
          }
        }
      ]
    }
  }
}