    "game_id": {
      "type": "string",
      "description": "Reference to the game"
    },
    "player_id": {
      "type": "string",
      "description": "Reference to the player"
    },
    "team_id": {
      "type": "string",
      "description": "Reference to the team"
    },
    "is_starter": {
      "type": "boolean",
      "default": false
    },
    "points_2": {
      "type": "number",
